<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <title>Estimasi Biaya Renovasi</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 10pt;
            color: #000;
            line-height: 1.3;
        }

        .header {
            width: 100%;
            margin-bottom: 20px;
            border-bottom: 2px solid #000;
            padding-bottom: 10px;
        }

        .header-table {
            width: 100%;
        }

        .logo {
            width: 150px;
            height: auto;
        }

        .title {
            text-align: center;
            font-weight: bold;
            font-size: 16pt;
            text-transform: uppercase;
        }

        .meta-info {
            margin-bottom: 15px;
            width: 100%;
        }

        .meta-info td {
            padding: 2px;
            vertical-align: top;
        }

        .label {
            font-weight: bold;
            width: 130px;
        }

        /* Table Style */
        .main-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        .main-table th,
        .main-table td {
            border: 1px solid #000;
            padding: 4px 6px;
        }

        .main-table th {
            background-color: #f0f0f0;
            text-align: center;
            font-weight: bold;
        }

        .text-center {
            text-align: center;
        }

        .text-right {
            text-align: right;
        }

        .text-bold {
            font-weight: bold;
        }

        .category-row {
            background-color: #e6e6e6;
            font-weight: bold;
        }

        /* Signatures */
        .signature-section {
            margin-top: 40px;
            width: 100%;
            page-break-inside: avoid;
        }

        .signature-table {
            width: 100%;
            text-align: center;
        }

        .signature-box {
            height: 80px;
        }

        .signature-name {
            font-weight: bold;
            text-decoration: underline;
        }
    </style>
</head>

<body>

    <div class="header">
        <table class="header-table">
            <tr>
                <td width="20%">
                    <img src="data:image/png;base64,"
                        alt="Company Logo" class="logo">
                </td>
                <td width="60%" class="title">
                    ESTIMASI BIAYA RENOVASI
                </td>
                <td width="20%" style="font-size: 9pt; text-align: right;">
                    Generated: <%= helpers.moment().format('DD/MM/YYYY') %>
                </td>
            </tr>
        </table>
    </div>

    <table class="meta-info">
        <tr>
            <td class="label">Cabang</td>
            <td>: <%= data.Cabang %>
            </td>
            <td class="label">Tanggal Pengajuan</td>
            <td>: <%= helpers.moment(data.Timestamp).format('DD MMMM YYYY') %>
            </td>
        </tr>
        <tr>
            <td class="label">Kode/Nama Toko</td>
            <td>: <%= data.Nama_Toko || data.Proyek %>
            </td>
            <td class="label">Nomor Ulok</td>
            <td>: <%= data.Nomor_Ulok || data['Nomor Ulok'] %>
            </td>
        </tr>
        <tr>
            <td class="label">Alamat</td>
            <td colspan="3">: <%= data.Alamat || '-' %>
            </td>
        </tr>
    </table>

    <table class="main-table">
        <thead>
            <tr>
                <th width="5%">No</th>
                <th width="40%">Uraian Pekerjaan</th>
                <th width="10%">Satuan</th>
                <th width="10%">Volume</th>
                <th width="15%">Harga Satuan</th>
                <th width="20%">Jumlah Harga</th>
            </tr>
        </thead>
        <tbody>
            <% let currentKategori="" ; let globalNo=1; let subNo=1; %>

                <% items.forEach(function(item) { %>

                    <% if (item.kategori !==currentKategori) { currentKategori=item.kategori; subNo=1; %>
                        <tr class="category-row">
                            <td class="text-center">
                                <%= globalNo++ %>
                            </td>
                            <td colspan="5" class="text-bold">
                                <%= item.kategori %>
                            </td>
                        </tr>
                        <% } %>

                            <tr>
                                <td class="text-center">
                                    <%= globalNo - 1 %>.<%= subNo++ %>
                                </td>
                                <td>
                                    <%= item.jenis %>
                                </td>
                                <td class="text-center">
                                    <%= item.satuan %>
                                </td>
                                <td class="text-center">
                                    <%= item.volume %>
                                </td>
                                <td class="text-right">
                                    <%= helpers.formatRupiah(item.harga) %>
                                </td>
                                <td class="text-right">
                                    <%= helpers.formatRupiah(item.total) %>
                                </td>
                            </tr>
                            <% }); %>

                                <tr>
                                    <td colspan="5" class="text-right text-bold">Sub Total</td>
                                    <td class="text-right text-bold">
                                        <%= helpers.formatRupiah(totals.subtotal) %>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="5" class="text-right">Pembulatan (Round Down)</td>
                                    <td class="text-right">
                                        <%= helpers.formatRupiah(totals.pembulatan) %>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="5" class="text-right">PPN 11%</td>
                                    <td class="text-right">
                                        <%= helpers.formatRupiah(totals.ppn) %>
                                    </td>
                                </tr>
                                <tr style="background-color: #f0f0f0;">
                                    <td colspan="5" class="text-right text-bold" style="font-size: 12pt;">GRAND TOTAL
                                        ESTIMASI</td>
                                    <td class="text-right text-bold" style="font-size: 12pt;">
                                        <%= helpers.formatRupiah(totals.grandTotal) %>
                                    </td>
                                </tr>
        </tbody>
    </table>

    <div class="signature-section">
        <table class="signature-table">
            <tr>
                <td width="33%">
                    Dibuat Oleh,<br><br>
                    <div class="signature-box"></div>
                    <span class="signature-name">
                        <%= data['Dibuat Oleh'] || 'PIC Building' %>
                    </span><br>
                    Building Support
                </td>
                <td width="33%">
                    Disetujui Oleh,<br><br>
                    <div class="signature-box">
                        <% if (data.Status==='Disetujui' || data.Status==='Menunggu Persetujuan Manajer' ) { %>
                            <span style="color: green; font-size: 0.8em;">(Digital Approved)</span>
                            <% } %>
                    </div>
                    <span class="signature-name">
                        <%= data['Pemberi Persetujuan Koordinator'] || 'Koordinator' %>
                    </span><br>
                    Building Coordinator
                </td>
                <td width="33%">
                    Diketahui Oleh,<br><br>
                    <div class="signature-box">
                        <% if (data.Status==='Disetujui' ) { %>
                            <span style="color: green; font-size: 0.8em;">(Digital Approved)</span>
                            <% } %>
                    </div>
                    <span class="signature-name">
                        <%= data['Pemberi Persetujuan Manager'] || 'Manager' %>
                    </span><br>
                    Building Manager
                </td>
            </tr>
        </table>
    </div>

</body>

</html>