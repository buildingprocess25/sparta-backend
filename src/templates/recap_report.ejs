<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <title>Rekapitulasi Estimasi Biaya</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 11pt;
            color: #000;
        }

        .header {
            width: 100%;
            margin-bottom: 30px;
            border-bottom: 2px solid #000;
            padding-bottom: 10px;
        }

        .title {
            text-align: center;
            font-weight: bold;
            font-size: 16pt;
            text-transform: uppercase;
        }

        .meta-info {
            width: 100%;
            margin-bottom: 20px;
        }

        .meta-info td {
            padding: 5px;
            vertical-align: top;
        }

        .label {
            font-weight: bold;
            width: 150px;
        }

        /* Table Style */
        .recap-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .recap-table th,
        .recap-table td {
            border: 1px solid #000;
            padding: 8px 10px;
        }

        .recap-table th {
            background-color: #f0f0f0;
            text-align: center;
            font-weight: bold;
        }

        .text-right {
            text-align: right;
        }

        .text-center {
            text-align: center;
        }

        .text-bold {
            font-weight: bold;
        }

        .total-row {
            background-color: #e6e6e6;
            font-weight: bold;
        }

        .grand-total-row {
            background-color: #d1ecf1;
            /* Light Blue */
            font-size: 12pt;
            font-weight: bold;
        }

        /* Footer / Signatures */
        .footer {
            margin-top: 50px;
            width: 100%;
        }

        .signature-table {
            width: 100%;
            text-align: center;
        }

        .signature-box {
            height: 80px;
        }
    </style>
</head>

<body>

    <div class="header">
        <h2 class="title">REKAPITULASI ESTIMASI BIAYA</h2>
    </div>

    <table class="meta-info">
        <tr>
            <td class="label">Cabang</td>
            <td>: <%= data.Cabang %>
            </td>
        </tr>
        <tr>
            <td class="label">Nama Toko / Proyek</td>
            <td>: <%= data.Nama_Toko || data.Proyek %>
            </td>
        </tr>
        <tr>
            <td class="label">Nomor Ulok</td>
            <td>: <%= data.Nomor_Ulok || data['Nomor Ulok'] %>
            </td>
        </tr>
        <tr>
            <td class="label">Tanggal</td>
            <td>: <%= helpers.moment(data.Timestamp).format('DD MMMM YYYY') %>
            </td>
        </tr>
    </table>

    <table class="recap-table">
        <thead>
            <tr>
                <th width="10%">No</th>
                <th width="60%">Uraian Pekerjaan</th>
                <th width="30%">Jumlah Harga</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td class="text-center">1</td>
                <td>Pekerjaan Sipil & ME (Non-SBO)</td>
                <td class="text-right">
                    <%= helpers.formatRupiah(totalNonSbo) %>
                </td>
            </tr>

            <tr>
                <td class="text-center">2</td>
                <td>Pekerjaan SBO (Sewa Barang Operasional)</td>
                <td class="text-right">
                    <%= helpers.formatRupiah(totalSbo) %>
                </td>
            </tr>

            <tr class="total-row">
                <td colspan="2" class="text-right">Sub Total</td>
                <td class="text-right">
                    <%= helpers.formatRupiah(totalNonSbo + totalSbo) %>
                </td>
            </tr>

            <% // Hitung ulang untuk display logic (harus konsisten dengan logic di controller/service) const
                rawTotal=totalNonSbo + totalSbo; const pembulatan=Math.floor(rawTotal / 10000) * 10000; const
                ppn=pembulatan * 0.11; const finalGrandTotal=pembulatan + ppn; %>

                <tr>
                    <td colspan="2" class="text-right">Pembulatan (Round Down ke puluhan ribu terdekat)</td>
                    <td class="text-right">
                        <%= helpers.formatRupiah(pembulatan) %>
                    </td>
                </tr>
                <tr>
                    <td colspan="2" class="text-right">PPN 11%</td>
                    <td class="text-right">
                        <%= helpers.formatRupiah(ppn) %>
                    </td>
                </tr>

                <tr class="grand-total-row">
                    <td colspan="2" class="text-right">GRAND TOTAL ESTIMASI</td>
                    <td class="text-right">
                        <%= helpers.formatRupiah(finalGrandTotal) %>
                    </td>
                </tr>
        </tbody>
    </table>

    <div class="footer">
        <table class="signature-table">
            <tr>
                <td width="50%">
                    Dibuat Oleh,<br><br>
                    <div class="signature-box"></div>
                    <strong>
                        <%= data['Dibuat Oleh'] || 'PIC Building' %>
                    </strong><br>
                    Building Support
                </td>
                <td width="50%">
                    Disetujui Oleh,<br><br>
                    <div class="signature-box">
                        <% if (data.Status==='Disetujui' ) { %>
                            <span style="color: green;">(Digital Approved)</span>
                            <% } %>
                    </div>
                    <strong>
                        <%= data['Pemberi Persetujuan Manager'] || 'Building Manager' %>
                    </strong><br>
                    Building Manager
                </td>
            </tr>
        </table>
    </div>

</body>

</html>